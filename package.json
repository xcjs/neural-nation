{
  "name": "neural-nation",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "allowScripts": {
    "better-sqlite3": true,
    "esbuild": true,
    "@parcel/watcher": true,
    "unrs-resolver": true
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "pretypecheck": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pretest": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:coverage": "nuxt prepare",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --project unit",
    "test:components": "vitest run --project components",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "build:template": "tsx scripts/build-template.ts",
    "fetch:data": "tsx scripts/fetch-geological-data.ts",
    "build:climate": "tsx scripts/build-climate-texture.ts",
    "db:seed-terrain": "tsx scripts/seed-terrain.ts",
    "db:seed-deposits": "tsx scripts/seed-deposits.ts",
    "db:rebuild": "node -e \"require('fs').rmSync('data/games/_template.db',{force:true})\" && tsx scripts/build-climate-texture.ts && tsx scripts/build-template.ts",
    "db:clean": "tsx scripts/clean-dbs.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pinia/nuxt": "^0.11.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.36.0",
    "nuxt": "^4.4.0",
    "pinia": "^3.0.0",
    "three": "^0.169.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.0.0",
    "@nuxt/test-utils": "^3.23.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.0",
    "@types/three": "^0.169.0",
    "@types/topojson-client": "^3.1.5",
    "@vitest/coverage-v8": "^3.2.0",
    "@vue/test-utils": "^2.4.0",
    "adm-zip": "^0.5.18",
    "autoprefixer": "^10.4.0",
    "commander": "^13.1.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-format": "^2.0.1",
    "happy-dom": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "topojson-client": "^3.1.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0",
    "vue-tsc": "^2.0.0",
    "world-atlas": "^2.0.2"
  }
}
