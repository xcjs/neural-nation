# Neural Nation environment variables

# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Public domain for MCP URLs (used in game creation response)
PUBLIC_DOMAIN=https://play.neuralnation.app

# Game cleanup
GAME_CLEANUP_ENABLED=true
GAME_CLEANUP_AGE_DAYS=7
GAME_CLEANUP_GRACE_DAYS=1
GAME_CLEANUP_INTERVAL_HOURS=6